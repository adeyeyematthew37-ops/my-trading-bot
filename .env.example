# ============================================
# TELEGRAM BOT CONFIGURATION
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ADMIN_USER_IDS=123456789,987654321  # Comma-separated Telegram user IDs

# ============================================
# RPC ENDPOINTS (get free keys from providers below)
# ============================================

# Ethereum - https://app.infura.io or https://alchemy.com
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY

# BNB Smart Chain - https://nodereal.io or use public
BSC_RPC_URL=https://bsc-dataseed1.binance.org

# Polygon - https://alchemy.com
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Arbitrum - https://alchemy.com
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Base - https://base.org/developers
BASE_RPC_URL=https://mainnet.base.org

# Avalanche - public
AVAX_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Solana - https://helius.dev (free tier)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ============================================
# API KEYS FOR PRICE DATA
# ============================================

# CoinGecko (free tier works) - https://coingecko.com/api
COINGECKO_API_KEY=your_coingecko_api_key

# 1inch for DEX aggregation - https://portal.1inch.dev
ONEINCH_API_KEY=your_1inch_api_key

# ============================================
# SECURITY
# ============================================
ENCRYPTION_KEY=generate_a_32_char_random_string_here
DB_PATH=./data/bot.db

# ============================================
# BOT SETTINGS
# ============================================
MAX_SLIPPAGE_PERCENT=1.0
DEFAULT_GAS_MULTIPLIER=1.2
DCA_CHECK_INTERVAL_MINUTES=5
MAX_WALLETS_PER_USER=5
